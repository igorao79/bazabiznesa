{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["./node_modules/tsx/dist/cli.mjs", "watch", "src/index.ts"],
      "port": 3001,
      "cwd": "backend",
      "env": {
        "DATABASE_URL": "file:./dev.db",
        "JWT_SECRET": "dev-secret",
        "PORT": "3001"
      }
    },
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["./node_modules/vite/bin/vite.js", "--port", "5173"],
      "port": 5173,
      "cwd": "frontend"
    }
  ]
}
